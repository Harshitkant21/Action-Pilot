# ==============================================================================
# ActionPilot Server Environment Settings
# ==============================================================================

# Server
PORT=3001
NODE_ENV="development"

# Database
# Note: DATABASE_URL must start with postgresql://
DATABASE_URL="postgresql://username:password@localhost:5432/database?schema=public"

# Redis
# Note: REDIS_URL must start with redis://
REDIS_URL="redis://localhost:6379"

# Authentication
# Note: In production, JWT_SECRET must be at least 32 characters long
JWT_SECRET="your-jwt-secret-at-least-32-chars-in-production"
JWT_EXPIRES_IN="7d"

# AI Integration
GEMINI_API_KEY=""
GEMINI_RETRY_LIMIT=2

# Notifications
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# Monitoring
STANDUP_COOLDOWN_HOURS=22
RISK_COOLDOWN_HOURS=4
RECOVERY_COOLDOWN_HOURS=4
RISK_THRESHOLD=70
MONITORING_SWEEP_INTERVAL_MS=3600000

# CORS
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:3001"

